FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip && \
    pip install lightgbm numerapi pandas numpy scikit-learn joblib

WORKDIR /app

# Copy files directly since we are building from agents/numerai context
COPY numerai_pipeline.py .
COPY crypto_pipeline.py .
COPY signal_pipeline.py .
COPY utils.py .
COPY models_config.json .
COPY run_all.sh .

# Copy pre-trained models
COPY models/*.pkl ./data/numerai/models/
COPY models/*.json ./data/numerai/models/

RUN chmod +x run_all.sh

CMD ["./run_all.sh"]
